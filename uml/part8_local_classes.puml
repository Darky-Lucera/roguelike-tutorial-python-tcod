@startuml part8_local_classes

!theme mimeograph

top to bottom direction

hide members
hide circle

skinparam roundcorner 10
skinparam classBackgroundColor #ece9e8
skinparam noteFontSize 10
skinparam noteBorderThickness 1
skinparam noteMargin 2
skinparam notePadding 2
skinparam nodesep 20
skinparam ranksep 35

set namespaceSeparator none

'--------------------------------------
' Classes
'--------------------------------------

class "Entity" as game.entities.entity.Entity #cce9c7 {
}

class "Actor" as game.entities.entity.Actor #cce9c7 {
}

class "Item" as game.entities.entity.Item #ccc9e8 {
}

class "BaseComponent" as game.entities.components.base_component.BaseComponent #cce9c7 {
}

class "ActorComponent" as game.entities.components.base_component.ActorComponent #ccc9e8 {
}

class "ItemComponent" as game.entities.components.base_component.ItemComponent #ccc9e8 {
}

class "Inventory" as game.entities.components.inventory.Inventory #ccc9e8 {
}

class "Consumable" as game.entities.components.consumable.Consumable #ccc9e8 {
}

class "HealingConsumable" as game.entities.components.consumable.HealingConsumable #ccc9e8 {
}

class "TreasureConsumable" as game.entities.components.consumable.TreasureConsumable #ccc9e8 {
}

class "Action" as game.actions.Action {
}

class "PickupAction" as game.actions.PickupAction #ccc9e8 {
}

class "ItemAction" as game.actions.ItemAction #ccc9e8 {
}

class "DropItem" as game.actions.DropItem #ccc9e8 {
}

class "MovementAction" as game.actions.MovementAction #cce9c7 {
}

class "GameState" as game.game_states.GameState #cce9c7 {
}

class "InventoryState" as game.game_states.InventoryState #ccc9e8 {
}

class "InventoryUseState" as game.game_states.InventoryUseState #ccc9e8 {
}

class "InventoryDropState" as game.game_states.InventoryDropState #ccc9e8 {
}

class "<color:#b57674>Impossible</color>" as game.exceptions.Impossible #ccc9e8 {
}

'--------------------------------------
' Relations
'--------------------------------------

' Inheritance: base class first, derived class second.
game.entities.entity.Entity <|-- game.entities.entity.Actor
game.entities.entity.Entity <|-- game.entities.entity.Item

game.entities.components.base_component.BaseComponent <|-- game.entities.components.base_component.ActorComponent
game.entities.components.base_component.BaseComponent <|-- game.entities.components.base_component.ItemComponent
game.entities.components.base_component.ActorComponent <|-- game.entities.components.inventory.Inventory
game.entities.components.base_component.ItemComponent <|-- game.entities.components.consumable.Consumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.HealingConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.TreasureConsumable

game.actions.Action <|-- game.actions.PickupAction
game.actions.Action <|-- game.actions.ItemAction
game.actions.ItemAction <|-- game.actions.DropItem

game.game_states.GameState <|-- game.game_states.InventoryState
game.game_states.InventoryState <|-- game.game_states.InventoryUseState
game.game_states.InventoryState <|-- game.game_states.InventoryDropState

' New ownership and references introduced by items and inventory.
game.entities.entity.Actor "inventory" *-- game.entities.components.inventory.Inventory
game.entities.entity.Item "consumable" *-- game.entities.components.consumable.Consumable
game.entities.components.inventory.Inventory -right-> "*" game.entities.entity.Item : items
game.actions.ItemAction -up-> game.entities.entity.Item : item

' Existing classes touched by the chapter.
game.actions.PickupAction --> game.entities.components.inventory.Inventory : adds item
game.actions.MovementAction --> game.entities.components.consumable.TreasureConsumable : on_contact
game.game_states.InventoryUseState --> game.actions.ItemAction : creates
game.game_states.InventoryDropState --> game.actions.DropItem : creates
game.actions.Action --> game.exceptions.Impossible : raises

'--------------------------------------
' Layout hints
'--------------------------------------

game.entities.entity.Entity -[hidden]down- game.entities.entity.Actor
game.entities.entity.Actor -[hidden]right- game.entities.entity.Item

game.entities.components.base_component.BaseComponent -[hidden]down- game.entities.components.base_component.ActorComponent
game.entities.components.base_component.ActorComponent -[hidden]down- game.entities.components.inventory.Inventory
game.entities.components.base_component.ActorComponent -[hidden]right- game.entities.components.base_component.ItemComponent
game.entities.components.base_component.ItemComponent -[hidden]down- game.entities.components.consumable.Consumable
game.entities.components.consumable.Consumable -[hidden]down- game.entities.components.consumable.HealingConsumable
game.entities.components.consumable.HealingConsumable -[hidden]right- game.entities.components.consumable.TreasureConsumable

game.actions.Action -[hidden]down- game.actions.PickupAction
game.actions.PickupAction -[hidden]right- game.actions.ItemAction
game.actions.ItemAction -[hidden]down- game.actions.DropItem
game.actions.DropItem -[hidden]right- game.actions.MovementAction

game.game_states.GameState -[hidden]down- game.game_states.InventoryState
game.game_states.InventoryState -[hidden]down- game.game_states.InventoryUseState
game.game_states.InventoryUseState -[hidden]right- game.game_states.InventoryDropState

legend top right
<size:11><back:#ece9e8>   </back> Unchanged - <back:#ccc9e8>   </back> New - <back:#cce9c7>   </back> Modified - <back:#ecdac7>   </back> Exercise</size>
endlegend

@enduml
