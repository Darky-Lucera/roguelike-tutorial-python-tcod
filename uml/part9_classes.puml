game.actions.ActionWithDirection <|-- game.actions.BumpAction
game.actions.ActionWithDirection <|-- game.actions.MeleeAction
game.actions.ActionWithDirection <|-- game.actions.MovementAction
game.actions.Action <|-- game.actions.EscapeAction
game.actions.Action <|-- game.actions.WaitAction
game.actions.Action <|-- game.actions.PickupAction
