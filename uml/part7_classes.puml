@startuml classes

!theme mimeograph

' top to bottom direction is the default, but keeping it makes the intent explicit.
top to bottom direction

' hide fields      ' same as attributes
' hide attributes  ' same as fields
' hide methods
' hide members     ' fields + methods
' hide stereotype

' hide class XXX
' hide interface XXX
' hide enum XXX
' hide << SomeStereotype>> XXX ' hide Serializable members
' hide SomeClassName XXX
' hide private XXX
' hide protected XXX
' hide package XXX

hide members

hide circle

'skinparam classAttributeIconSize 0
'skinparam defaultFontName "Segoe UI"
'skinparam classFontName "Segoe UI"
'skinparam classFontSize 10
'skinparam classAttributeFontSize 9
'skinparam shadowing true
skinparam roundcorner 10
skinparam classBackgroundColor #ece9e8

skinparam noteFontSize 10
skinparam noteBorderThickness 1
skinparam noteMargin 2
skinparam notePadding 2

skinparam nodesep 10
skinparam ranksep 30

set namespaceSeparator none

'--------------------------------------
' Classes
'--------------------------------------

class "Action" as game.actions.Action {
}

class "ActionWithDirection" as game.actions.ActionWithDirection {
}

class "Actor" as game.entities.entity.Actor {
}

class "BaseAI" as game.entities.components.ai.BaseAI {
}

class "BaseComponent" as game.entities.components.base_component.BaseComponent {
}

class "BumpAction" as game.actions.BumpAction {
}

class "CowardEnemy" as game.entities.components.ai.CowardEnemy {
}

class "Engine" as game.engine.Engine #cce9c7 {
}

class "Entity" as game.entities.entity.Entity {
}

class "EscapeAction" as game.actions.EscapeAction {
}

class "GameState" as game.game_states.GameState #ccc9e8 {
}

class "Fighter" as game.entities.components.fighter.Fighter #cce9c7 {
}

class "GameMap" as game.map.game_map.GameMap {
}

class "GameOverState" as game.game_states.GameOverState #ccc9e8 {
}

class "HostileEnemy" as game.entities.components.ai.HostileEnemy {
}

class "MeleeAction" as game.actions.MeleeAction {
}


class "MainGameState" as game.game_states.MainGameState #ccc9e8 {
}

class "Message" as game.message_log.Message #ccc9e8 {
}

class "MessageLog" as game.message_log.MessageLog #ccc9e8 {
}

class "MovementAction" as game.actions.MovementAction {
}

class "RectangularRoom" as game.map.map_generator.RectangularRoom {
}

class "RenderOrder" as game.entities.render_order.RenderOrder {
}

class "WaitAction" as game.actions.WaitAction {
}

'--------------------------------------
' Relations
'--------------------------------------

' Inheritance: base class first, derived class second.
game.actions.Action <|-- game.actions.ActionWithDirection
game.actions.ActionWithDirection <|-- game.actions.BumpAction
game.actions.Action <|-- game.actions.EscapeAction
game.actions.ActionWithDirection <|-- game.actions.MeleeAction
game.actions.ActionWithDirection <|-- game.actions.MovementAction
game.actions.Action <|-- game.actions.WaitAction

game.entities.components.base_component.BaseComponent <|-- game.entities.components.ai.BaseAI
game.entities.components.ai.BaseAI <|-- "Ex. 6.3" game.entities.components.ai.CowardEnemy
game.entities.components.ai.BaseAI <|-- game.entities.components.ai.HostileEnemy
game.entities.components.base_component.BaseComponent <|-- game.entities.components.fighter.Fighter
game.entities.entity.Entity <|-- game.entities.entity.Actor

game.game_states.GameState <|-- game.game_states.GameOverState
game.game_states.GameState <|-- game.game_states.MainGameState

' Ownership / references / associations.
game.entities.components.base_component.BaseComponent --> game.entities.entity.Entity : entity
game.map.game_map.GameMap " * " *-- game.entities.entity.Entity : entities
game.engine.Engine *-- game.game_states.GameState : game_state
game.engine.Engine *-- game.game_states.GameOverState : game_state
game.game_states.GameState --> game.engine.Engine : engine
game.engine.Engine *-- game.entities.entity.Actor : player
game.entities.entity.Entity --> game.entities.render_order.RenderOrder : render_order
game.engine.Engine *-- game.map.game_map.GameMap : game_map

' MessageLog contains many Message objects and creates them.
game.message_log.MessageLog *-- "*" game.message_log.Message : contains

'--------------------------------------
' Layout hints
'--------------------------------------

' Engine should sit above the main runtime objects.
game.engine.Engine -[hidden]down- game.map.game_map.GameMap
game.engine.Engine -[hidden]down- game.game_states.GameState
game.engine.Engine -[hidden]down- game.actions.Action
game.engine.Engine -[hidden]down- game.message_log.MessageLog

' GameMap should be above Entity. Entity and BaseComponent should be roughly aligned.
game.map.game_map.GameMap -[hidden]down- game.entities.entity.Entity
game.map.game_map.GameMap -[hidden]down- game.entities.components.base_component.BaseComponent
game.entities.entity.Entity -[hidden]right- game.entities.components.base_component.BaseComponent

' Actor must be below Entity.
game.entities.entity.Entity -[hidden]down- game.entities.entity.Actor

' RenderOrder is a value used by Entity, so keep it below/near Entity.
game.entities.entity.Entity -[hidden]down- game.entities.render_order.RenderOrder

' Inheritance trees: keep base classes above derived classes.
game.actions.Action -[hidden]down- game.actions.ActionWithDirection
game.actions.Action -[hidden]down- game.actions.WaitAction
game.actions.Action -[hidden]down- game.actions.EscapeAction

game.actions.ActionWithDirection -[hidden]down- game.actions.BumpAction
game.actions.ActionWithDirection -[hidden]down- game.actions.MeleeAction
game.actions.ActionWithDirection -[hidden]down- game.actions.MovementAction

game.game_states.GameState -[hidden]down- game.game_states.GameOverState
game.game_states.GameState -[hidden]down- game.game_states.MainGameState

game.entities.components.base_component.BaseComponent -[hidden]down- game.entities.components.fighter.Fighter
game.entities.components.base_component.BaseComponent -[hidden]down- game.entities.components.ai.BaseAI

game.entities.components.ai.BaseAI -[hidden]down- game.entities.components.ai.CowardEnemy
game.entities.components.ai.BaseAI -[hidden]down- game.entities.components.ai.HostileEnemy

' MessageLog should be above the messages
game.message_log.MessageLog -[hidden]down- game.message_log.Message
game.actions.EscapeAction -[hidden]down- game.message_log.MessageLog

' Keep map-generation classes below
game.entities.entity.Actor -[hidden]down- game.map.map_generator.RectangularRoom

legend top right
<size:11><back:#ece9e8>   </back> Unchanged - <back:#ccc9e8>   </back> New - <back:#cce9c7>   </back> Modified - <back:#ecdac7>   </back> Exercise</size>
endlegend

@enduml
