game.actions.Action <|-- game.actions.TargetingAction
game.actions.TargetingAction <|-- game.actions.SingleRangedTargetingAction
game.actions.TargetingAction <|-- game.actions.AreaRangedTargetingAction

game.entities.entity.Entity <|-- game.entities.entity.Actor
game.entities.entity.Entity <|-- game.entities.entity.Item

game.entities.components.base_component.BaseComponent <|-- game.entities.components.base_component.ActorComponent
game.entities.components.base_component.ActorComponent <|-- game.entities.components.fighter.Fighter
game.entities.components.base_component.ActorComponent <|-- game.entities.components.ai.BaseAI
game.entities.components.base_component.ActorComponent <|-- game.entities.components.inventory.Inventory
game.entities.components.ai.BaseAI <|-- game.entities.components.ai.HostileEnemy
game.entities.components.ai.BaseAI <|-- game.entities.components.ai.CowardEnemy
game.entities.components.ai.BaseAI <|-- game.entities.components.ai.ConfusedEnemy

game.entities.components.base_component.BaseComponent <|-- game.entities.components.base_component.ItemComponent
game.entities.components.base_component.ItemComponent <|-- game.entities.components.consumable.Consumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.BackpackConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.ConfusionConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.FireballDamageConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.HealingConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.LightningDamageConsumable
game.entities.components.consumable.Consumable <|-- game.entities.components.consumable.MappingConsumable
